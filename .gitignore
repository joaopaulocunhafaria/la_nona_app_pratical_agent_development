# Monorepo: regras genéricas para qualquer subprojeto (app/, backend/).
# Cada subprojeto mantém seu próprio .gitignore com regras específicas
# (Flutter em app/.gitignore, Maven/Spring Boot em backend/.gitignore).

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/
